<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:sport_rent.ViewModels"
             x:DataType="vm:EquipmentViewModel"
             x:Class="sport_rent.Views.EquipmentView">

    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,0,0,20">
            <TextBox Text="{Binding SearchText}" Watermark="🔍 Пошук по назві або категорії" Width="400" Height="45"/>
            <Button Content="Додати спорядження" Command="{Binding SaveEquipmentCommand}" Height="45"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding EquipmentList}" 
                  SelectedItem="{Binding SelectedEquipment}" 
                  Grid.Row="1" 
                  AutoGenerateColumns="True"
                  IsReadOnly="False"/>

        <StackPanel Orientation="Horizontal" Spacing="10" Grid.Row="2" Margin="0,15,0,0">
            <Button Content="Зберегти" Command="{Binding SaveEquipmentCommand}" Height="48"/>
            <Button Content="Видалити" Command="{Binding DeleteEquipmentCommand}" Height="48" Background="#EF4444"/>
        </StackPanel>
    </Grid>
</UserControl>