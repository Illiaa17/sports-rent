<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:sport_rent.ViewModels"
             x:DataType="vm:CustomerViewModel"
             x:Class="sport_rent.Views.CustomerView">

    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,0,0,20">
            <TextBox Text="{Binding SearchText}" Watermark="🔍 Пошук клієнта" Width="400" Height="45"/>
            <Button Content="Додати клієнта" Command="{Binding SaveCustomerCommand}" Height="45"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Customers}" 
                  SelectedItem="{Binding SelectedCustomer}" 
                  Grid.Row="1"/>

        <StackPanel Orientation="Horizontal" Spacing="10" Grid.Row="2" Margin="0,15,0,0">
            <Button Content="Зберегти" Command="{Binding SaveCustomerCommand}" Height="48"/>
            <Button Content="Видалити" Command="{Binding DeleteCustomerCommand}" Height="48" Background="#EF4444"/>
        </StackPanel>
    </Grid>
</UserControl>