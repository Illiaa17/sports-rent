<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:sport_rent.ViewModels"
        x:Class="sport_rent.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="SportRent"
        Width="520"
        Height="480"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Grid Background="#0F172A" RowDefinitions="*,Auto">
        <StackPanel Spacing="25" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Прокат Спорт" FontSize="42" Foreground="#00CC66" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBox Text="{Binding LoginName}" Watermark="Логін" Width="320" Height="50"/>
            <TextBox Text="{Binding Password}" Watermark="Пароль" PasswordChar="*" Width="320" Height="50"/>
            <Button Content="Увійти" Command="{Binding LoginCommand}" Width="320" Height="55" FontSize="18"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
