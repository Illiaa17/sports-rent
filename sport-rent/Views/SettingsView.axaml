<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:sport_rent.ViewModels"
             x:DataType="vm:SettingsViewModel"
             x:Class="sport_rent.Views.SettingsView">

    <StackPanel Spacing="25" Margin="40">
        <TextBlock Text="Налаштування" FontSize="32" FontWeight="Bold"/>

        <Border BorderThickness="1" CornerRadius="6" Padding="16">
            <StackPanel Spacing="10">
                <TextBlock Text="Мова інтерфейсу" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"/>
                <Button Content="Українська" Command="{Binding ChangeLanguageCommand}" CommandParameter="uk"/>
                <Button Content="English" Command="{Binding ChangeLanguageCommand}" CommandParameter="en"/>
            </StackPanel>
        </Border>

        <Border BorderThickness="1" CornerRadius="6" Padding="16">
            <StackPanel Spacing="10">
                <TextBlock Text="Тема" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"/>
                <Button Content="Перемкнути тему (Light/Dark)" Command="{Binding ToggleThemeCommand}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>