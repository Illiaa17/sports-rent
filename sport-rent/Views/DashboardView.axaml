<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:sport_rent.ViewModels"
             x:DataType="vm:DashboardViewModel"
             x:Class="sport_rent.Views.DashboardView">

    <ScrollViewer>
        <StackPanel Spacing="28">
            <TextBlock Classes="h1" Text="{Binding Loc[DashboardTitle]}"/>

            <WrapPanel>
                <Border Classes="stat">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Loc[TotalEquipmentLabel]}" FontSize="13" Foreground="{DynamicResource TextLo}"/>
                        <TextBlock Text="{Binding TotalEquipment}" FontSize="44" FontWeight="Bold" Foreground="{DynamicResource Accent}"/>
                    </StackPanel>
                </Border>

                <Border Classes="stat">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Loc[ActiveRentalsLabel]}" FontSize="13" Foreground="{DynamicResource TextLo}"/>
                        <TextBlock Text="{Binding ActiveRentals}" FontSize="44" FontWeight="Bold" Foreground="{DynamicResource Warning}"/>
                    </StackPanel>
                </Border>

                <Border Classes="stat">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Loc[TotalCustomersLabel]}" FontSize="13" Foreground="{DynamicResource TextLo}"/>
                        <TextBlock Text="{Binding TotalCustomers}" FontSize="44" FontWeight="Bold" Foreground="{DynamicResource Info}"/>
                    </StackPanel>
                </Border>

                <Border Classes="stat">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Loc[TodayRevenueLabel]}" FontSize="13" Foreground="{DynamicResource TextLo}"/>
                        <TextBlock Text="{Binding TodayRevenue, StringFormat={}{0:F2}}"
                                   FontSize="38" FontWeight="Bold" Foreground="{DynamicResource Accent}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
