<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:sport_rent.ViewModels"
             x:DataType="vm:DashboardViewModel"
             x:Class="sport_rent.Views.DashboardView">

    <StackPanel Spacing="30">
        <TextBlock Text="Головна панель" FontSize="32" FontWeight="Bold" Foreground="White"/>

        <WrapPanel Spacing="20">
            <Border Background="#1E2937" CornerRadius="12" Padding="30" Width="280">
                <StackPanel>
                    <TextBlock Text="🎿 Усього спорядження" FontSize="16" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding TotalEquipment}" FontSize="48" FontWeight="Bold" Foreground="#22C55E"/>
                </StackPanel>
            </Border>

            <Border Background="#1E2937" CornerRadius="12" Padding="30" Width="280">
                <StackPanel>
                    <TextBlock Text="📋 Активних оренд" FontSize="16" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding ActiveRentals}" FontSize="48" FontWeight="Bold" Foreground="#EAB308"/>
                </StackPanel>
            </Border>

            <Border Background="#1E2937" CornerRadius="12" Padding="30" Width="280">
                <StackPanel>
                    <TextBlock Text="👥 Клієнтів" FontSize="16" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding TotalCustomers}" FontSize="48" FontWeight="Bold" Foreground="#3B82F6"/>
                </StackPanel>
            </Border>
        </WrapPanel>
    </StackPanel>
</UserControl>