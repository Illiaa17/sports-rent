<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:sport_rent"
             x:Class="sport_rent.App">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

        <!-- ===== Global Styles ===== -->

        <!-- Default Button -->
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Primary button -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Danger button -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{DynamicResource Danger}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Danger}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Opacity" Value="0.85"/>
        </Style>

        <!-- Ghost button (transparent, subtle hover) -->
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextHi}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}"/>
        </Style>

        <!-- Icon button (square, centered, rounded — used for pagination arrows) -->
        <Style Selector="Button.icon-btn">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Sidebar nav button -->
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextHi}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextHi}"/>
        </Style>

        <!-- TextBox -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="38"/>
        </Style>

        <!-- ComboBox -->
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="MinHeight" Value="38"/>
        </Style>

        <!-- DataGrid -->
        <Style Selector="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Border}"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLo}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <!-- Reusable card -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 2 12 0 #15000000"/>
        </Style>

        <!-- Stat card (Dashboard tiles) -->
        <Style Selector="Border.stat">
            <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="26"/>
            <Setter Property="Width" Value="260"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
            <Setter Property="BoxShadow" Value="0 3 18 0 #22000000"/>
        </Style>

        <!-- Heading -->
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextHi}"/>
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextHi}"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{DynamicResource TextLo}"/>
        </Style>
        <Style Selector="TextBlock.danger">
            <Setter Property="Foreground" Value="{DynamicResource Danger}"/>
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://sport-rent/Controls/FloatingLabelBox.axaml"/>
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>

                <!-- ================= DARK THEME ================= -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PrimaryBg"   Color="#0B1220"/>
                    <SolidColorBrush x:Key="SurfaceBg"   Color="#151E31"/>
                    <SolidColorBrush x:Key="SurfaceAlt"  Color="#1E2A44"/>
                    <SolidColorBrush x:Key="Border"      Color="#2B3756"/>
                    <SolidColorBrush x:Key="TextHi"      Color="#F1F5F9"/>
                    <SolidColorBrush x:Key="TextLo"      Color="#94A3B8"/>
                    <SolidColorBrush x:Key="Accent"      Color="#10B981"/>
                    <SolidColorBrush x:Key="AccentHover" Color="#0EA371"/>
                    <SolidColorBrush x:Key="Danger"      Color="#F43F5E"/>
                    <SolidColorBrush x:Key="Warning"     Color="#F59E0B"/>
                    <SolidColorBrush x:Key="Info"        Color="#6366F1"/>
                </ResourceDictionary>

                <!-- ================= LIGHT THEME ================= -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PrimaryBg"   Color="#F8FAFC"/>
                    <SolidColorBrush x:Key="SurfaceBg"   Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="SurfaceAlt"  Color="#F1F5F9"/>
                    <SolidColorBrush x:Key="Border"      Color="#E2E8F0"/>
                    <SolidColorBrush x:Key="TextHi"      Color="#0F172A"/>
                    <SolidColorBrush x:Key="TextLo"      Color="#64748B"/>
                    <SolidColorBrush x:Key="Accent"      Color="#059669"/>
                    <SolidColorBrush x:Key="AccentHover" Color="#047857"/>
                    <SolidColorBrush x:Key="Danger"      Color="#DC2626"/>
                    <SolidColorBrush x:Key="Warning"     Color="#D97706"/>
                    <SolidColorBrush x:Key="Info"        Color="#4F46E5"/>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
